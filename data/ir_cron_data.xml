<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Monta Stock Sync — Scheduled Action (Cron Job)
            ===============================================
            Runs every 24 hours and calls MontaStockSync._cron_sync_monta_stock().

            noupdate="1" ensures that upgrading the module will NOT reset
            a user-customized schedule (e.g. if admin changed it to 12h).
        -->
        <record id="ir_cron_monta_stock_sync" model="ir.cron">
            <field name="name">Monta: Sync Stock Quantities</field>
            <field name="model_id" ref="model_monta_stock_sync"/>
            <field name="state">code</field>
            <field name="code">model._cron_sync_monta_stock()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">24</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
